<?xml version="1.0" encoding="UTF-8"?>
<rig type="human" name="Humanoid">
    <description>Standard humanoid biped rig with arms, legs, spine, and head</description>
    
    <bone name="Hips" parent="">
        <position x="0" y="1.0" z="0"/>
        <endPosition x="0" y="1.2" z="0"/>
    </bone>
    
    <!-- Spine -->
    <bone name="Spine" parent="Hips">
        <position x="0" y="1.0" z="0"/>
        <endPosition x="0" y="1.3" z="0"/>
    </bone>
    
    <bone name="Chest" parent="Spine">
        <position x="0" y="1.3" z="0"/>
        <endPosition x="0" y="1.5" z="0"/>
    </bone>
    
    <bone name="Neck" parent="Chest">
        <position x="0" y="1.5" z="0"/>
        <endPosition x="0" y="1.7" z="0"/>
    </bone>
    
    <bone name="Head" parent="Neck">
        <position x="0" y="1.7" z="0"/>
        <endPosition x="0" y="1.95" z="0"/>
    </bone>
    
    <!-- Left Arm -->
    <bone name="LeftShoulder" parent="Chest">
        <position x="0.2" y="1.45" z="0"/>
        <endPosition x="0.35" y="1.4" z="0"/>
    </bone>
    
    <bone name="LeftUpperArm" parent="LeftShoulder">
        <position x="0.35" y="1.4" z="0"/>
        <endPosition x="0.6" y="1.2" z="0"/>
    </bone>
    
    <bone name="LeftForeArm" parent="LeftUpperArm">
        <position x="0.6" y="1.2" z="0"/>
        <endPosition x="0.8" y="1.0" z="0"/>
    </bone>
    
    <bone name="LeftHand" parent="LeftForeArm">
        <position x="0.8" y="1.0" z="0"/>
        <endPosition x="0.95" y="0.95" z="0"/>
    </bone>
    
    <!-- Right Arm -->
    <bone name="RightShoulder" parent="Chest">
        <position x="-0.2" y="1.45" z="0"/>
        <endPosition x="-0.35" y="1.4" z="0"/>
    </bone>
    
    <bone name="RightUpperArm" parent="RightShoulder">
        <position x="-0.35" y="1.4" z="0"/>
        <endPosition x="-0.6" y="1.2" z="0"/>
    </bone>
    
    <bone name="RightForeArm" parent="RightUpperArm">
        <position x="-0.6" y="1.2" z="0"/>
        <endPosition x="-0.8" y="1.0" z="0"/>
    </bone>
    
    <bone name="RightHand" parent="RightForeArm">
        <position x="-0.8" y="1.0" z="0"/>
        <endPosition x="-0.95" y="0.95" z="0"/>
    </bone>
    
    <!-- Left Leg -->
    <bone name="LeftUpperLeg" parent="Hips">
        <position x="0.1" y="1.0" z="0"/>
        <endPosition x="0.1" y="0.6" z="0"/>
    </bone>
    
    <bone name="LeftLowerLeg" parent="LeftUpperLeg">
        <position x="0.1" y="0.6" z="0"/>
        <endPosition x="0.1" y="0.2" z="0"/>
    </bone>
    
    <bone name="LeftFoot" parent="LeftLowerLeg">
        <position x="0.1" y="0.2" z="0"/>
        <endPosition x="0.1" y="0.0" z="0.2"/>
    </bone>
    
    <!-- Right Leg -->
    <bone name="RightUpperLeg" parent="Hips">
        <position x="-0.1" y="1.0" z="0"/>
        <endPosition x="-0.1" y="0.6" z="0"/>
    </bone>
    
    <bone name="RightLowerLeg" parent="RightUpperLeg">
        <position x="-0.1" y="0.6" z="0"/>
        <endPosition x="-0.1" y="0.2" z="0"/>
    </bone>
    
    <bone name="RightFoot" parent="RightLowerLeg">
        <position x="-0.1" y="0.2" z="0"/>
        <endPosition x="-0.1" y="0.0" z="0.2"/>
    </bone>
    
</rig>
