<?xml version="1.0" encoding="UTF-8"?>
<rig type="generic" name="Generic">
    <description>Generic custom rig with a basic skeleton structure</description>
    
    <!-- Root -->
    <bone name="Root" parent="">
        <position x="0" y="0.5" z="0"/>
        <endPosition x="0" y="0.7" z="0"/>
    </bone>
    
    <!-- Main Body -->
    <bone name="Body" parent="Root">
        <position x="0" y="0.7" z="0"/>
        <endPosition x="0" y="1.0" z="0"/>
    </bone>
    
    <!-- Head -->
    <bone name="Head" parent="Body">
        <position x="0" y="1.0" z="0"/>
        <endPosition x="0" y="1.3" z="0"/>
    </bone>
    
    <!-- Left Limb 1 -->
    <bone name="LeftLimb1" parent="Body">
        <position x="0.2" y="0.85" z="0"/>
        <endPosition x="0.5" y="0.7" z="0"/>
    </bone>
    
    <bone name="LeftLimb1End" parent="LeftLimb1">
        <position x="0.5" y="0.7" z="0"/>
        <endPosition x="0.7" y="0.55" z="0"/>
    </bone>
    
    <!-- Right Limb 1 -->
    <bone name="RightLimb1" parent="Body">
        <position x="-0.2" y="0.85" z="0"/>
        <endPosition x="-0.5" y="0.7" z="0"/>
    </bone>
    
    <bone name="RightLimb1End" parent="RightLimb1">
        <position x="-0.5" y="0.7" z="0"/>
        <endPosition x="-0.7" y="0.55" z="0"/>
    </bone>
    
    <!-- Left Limb 2 -->
    <bone name="LeftLimb2" parent="Root">
        <position x="0.15" y="0.5" z="0"/>
        <endPosition x="0.4" y="0.2" z="0"/>
    </bone>
    
    <bone name="LeftLimb2End" parent="LeftLimb2">
        <position x="0.4" y="0.2" z="0"/>
        <endPosition x="0.5" y="0.0" z="0.1"/>
    </bone>
    
    <!-- Right Limb 2 -->
    <bone name="RightLimb2" parent="Root">
        <position x="-0.15" y="0.5" z="0"/>
        <endPosition x="-0.4" y="0.2" z="0"/>
    </bone>
    
    <bone name="RightLimb2End" parent="RightLimb2">
        <position x="-0.4" y="0.2" z="0"/>
        <endPosition x="-0.5" y="0.0" z="0.1"/>
    </bone>
    
</rig>
