<?xml version="1.0" encoding="UTF-8"?>
<rig type="fish" name="Fish">
    <description>Fish rig with fins and tail</description>
    
    <bone name="Root" parent="">
        <position x="0" y="0" z="0"/>
        <endPosition x="0" y="0" z="0.5"/>
    </bone>
    
    <!-- Body -->
    <bone name="Head" parent="Root">
        <position x="0" y="0" z="0.25"/>
        <endPosition x="0" y="0" z="0.5"/>
    </bone>
    
    <bone name="BodyFront" parent="Head">
        <position x="0" y="0" z="0.25"/>
        <endPosition x="0" y="0" z="0"/>
    </bone>
    
    <bone name="BodyMid" parent="BodyFront">
        <position x="0" y="0" z="0"/>
        <endPosition x="0" y="0" z="-0.25"/>
    </bone>
    
    <bone name="BodyRear" parent="BodyMid">
        <position x="0" y="0" z="-0.25"/>
        <endPosition x="0" y="0" z="-0.4"/>
    </bone>
    
    <!-- Tail -->
    <bone name="TailStart" parent="BodyRear">
        <position x="0" y="0" z="-0.4"/>
        <endPosition x="0" y="0" z="-0.6"/>
    </bone>
    
    <bone name="TailEnd" parent="TailStart">
        <position x="0" y="0" z="-0.6"/>
        <endPosition x="0" y="0" z="-0.9"/>
    </bone>
    
    <!-- Dorsal Fin -->
    <bone name="DorsalFinFront" parent="BodyFront">
        <position x="0" y="0" z="0.15"/>
        <endPosition x="0" y="0.3" z="0.15"/>
    </bone>
    
    <bone name="DorsalFinMid" parent="BodyMid">
        <position x="0" y="0" z="-0.1"/>
        <endPosition x="0" y="0.25" z="-0.1"/>
    </bone>
    
    <bone name="DorsalFinRear" parent="BodyRear">
        <position x="0" y="0" z="-0.35"/>
        <endPosition x="0" y="0.15" z="-0.35"/>
    </bone>
    
    <!-- Ventral Fin -->
    <bone name="VentralFinFront" parent="BodyFront">
        <position x="0" y="0" z="0.15"/>
        <endPosition x="0" y="-0.3" z="0.15"/>
    </bone>
    
    <bone name="VentralFinMid" parent="BodyMid">
        <position x="0" y="0" z="-0.1"/>
        <endPosition x="0" y="-0.25" z="-0.1"/>
    </bone>
    
    <bone name="VentralFinRear" parent="BodyRear">
        <position x="0" y="0" z="-0.35"/>
        <endPosition x="0" y="-0.15" z="-0.35"/>
    </bone>
    
    <!-- Left Pectoral Fin -->
    <bone name="LeftPectoralFin" parent="BodyFront">
        <position x="0" y="0" z="0.2"/>
        <endPosition x="-0.4" y="0" z="0.1"/>
    </bone>
    
    <!-- Right Pectoral Fin -->
    <bone name="RightPectoralFin" parent="BodyFront">
        <position x="0" y="0" z="0.2"/>
        <endPosition x="0.4" y="0" z="0.1"/>
    </bone>
    
    <!-- Left Pelvic Fin -->
    <bone name="LeftPelvicFin" parent="BodyMid">
        <position x="0" y="0" z="-0.15"/>
        <endPosition x="-0.3" y="0" z="-0.25"/>
    </bone>
    
    <!-- Right Pelvic Fin -->
    <bone name="RightPelvicFin" parent="BodyMid">
        <position x="0" y="0" z="-0.15"/>
        <endPosition x="0.3" y="0" z="-0.25"/>
    </bone>
    
</rig>
